# Cisco AI Defense
AIDEFENSE_API_KEY=your-ai-defense-api-key-here
AIDEFENSE_REGION=us
AIDEFENSE_ENDPOINT=https://us.api.inspect.aidefense.security.cisco.com
AIDEFENSE_MODE=enforce
AIDEFENSE_FAIL_OPEN=true
AIDEFENSE_TIMEOUT=30
AIDEFENSE_TIMEOUT_MS=30000
AIDEFENSE_RETRY_TOTAL=3
AIDEFENSE_RETRY_BACKOFF=1.0

# OpenAI (for examples)
OPENAI_API_KEY=your-openai-api-key-here
